{
  "name": "personal-website-interactions",
  "private": true,
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "pages:deploy": "wrangler pages deploy pages/public --project-name personal-website-interactions-api --branch main --commit-dirty=true",
    "db:local": "wrangler d1 execute personal-website-interactions --local --file=./schema.sql",
    "db:remote": "wrangler d1 execute personal-website-interactions --remote --file=./schema.sql"
  },
  "devDependencies": {
    "wrangler": "^4.20.0"
  }
}
