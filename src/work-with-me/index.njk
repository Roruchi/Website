<section class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-20">
  <div class="section-intro mb-10">
    <div class="eyebrow">Talks and explorations</div>
    <h2>Practical, reflective sessions for engineering audiences.</h2>
    <p>These sessions can be delivered as talks or expanded into more interactive workshops, depending on your audience, time, and desired depth.</p>
  </div>

  <div class="topic-list">
    {%- for talk in publicTalks -%}
    <article class="topic-card">
      <span class="topic-index">{% if loop.index < 10 %}0{% endif %}{{ loop.index }}</span>
      <div>
        <div class="talk-card-meta">
          <span class="talk-status">{{ talk.status }}</span>
          <span>{{ talk.audience }}</span>
        </div>
        <h2><a href="/talks/{{ talk.slug }}/">{{ talk.title }}</a></h2>
        <p>{{ talk.description }}</p>
        <p class="topic-outcome">{{ talk.takeaways[0] }}</p>
        <a href="/talks/{{ talk.slug }}/" class="text-link mt-5 inline-flex">View session details</a>
      </div>
    </article>
    {%- else -%}
    <p>No sessions are currently selected for the public showcase.</p>
    {%- endfor -%}
  </div>
</section>

