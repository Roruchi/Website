---
layout: base.njk
title: Talks
description: Conference talks and workshops on platform engineering, TypeScript, and developer experience.
permalink: /talks/index.html
---
<div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
  <div class="mb-12">
    <h1 class="text-4xl md:text-5xl font-extrabold text-stone-900 mb-4">Talks</h1>
    <p class="text-xl text-stone-500 max-w-2xl">Conference talks and workshops on platform engineering, TypeScript, and developer experience.</p>
  </div>

  <!-- Timeline -->
  <div class="relative">
    <div class="absolute left-4 md:left-8 top-0 bottom-0 w-px bg-stone-200"></div>
    <div class="space-y-8">
      {%- for talk in collections.talk | reverse -%}
      <div class="relative pl-12 md:pl-20">
        <!-- Timeline dot -->
        <div class="absolute left-2 md:left-6 top-6 w-4 h-4 rounded-full bg-amber-500 border-4 border-white shadow-sm ring-2 ring-amber-200"></div>

        <article class="group bg-white rounded-2xl border border-stone-200 hover:border-amber-300 hover:shadow-lg transition-all duration-200 p-6 md:p-8">
          <div class="flex flex-col md:flex-row md:items-start md:justify-between gap-4 mb-4">
            <div>
              <h2 class="text-lg font-bold text-stone-900 group-hover:text-amber-800 transition-colors leading-snug">
                <a href="{{ talk.url }}">{{ talk.data.title }}</a>
              </h2>
            </div>
            <div class="flex-shrink-0 flex flex-wrap gap-2">
              <span class="inline-flex items-center text-xs font-medium text-amber-800 bg-amber-100 px-2.5 py-1 rounded-full whitespace-nowrap">
                🏛️ {{ talk.data.event }}
              </span>
              <span class="inline-flex items-center text-xs font-medium text-stone-600 bg-stone-100 px-2.5 py-1 rounded-full whitespace-nowrap">
                📅 {{ talk.data.date }}
              </span>
            </div>
          </div>
          <p class="text-stone-500 text-sm leading-relaxed mb-4">{{ talk.data.description }}</p>
          <div class="flex gap-3">
            {%- if talk.data.slides -%}
            <a href="{{ talk.data.slides }}" class="inline-flex items-center gap-1.5 text-xs font-semibold text-stone-700 hover:text-stone-900 bg-stone-100 hover:bg-stone-200 px-3 py-1.5 rounded-lg transition-colors">
              <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 12l3-3 3 3 4-4M8 21l4-4 4 4M3 4h18M4 4h16v12a1 1 0 01-1 1H5a1 1 0 01-1-1V4z"/></svg>
              Slides
            </a>
            {%- endif -%}
            {%- if talk.data.video -%}
            <a href="{{ talk.data.video }}" class="inline-flex items-center gap-1.5 text-xs font-semibold text-amber-700 hover:text-amber-800 bg-amber-50 hover:bg-amber-100 px-3 py-1.5 rounded-lg transition-colors">
              <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14.752 11.168l-3.197-2.132A1 1 0 0010 9.87v4.263a1 1 0 001.555.832l3.197-2.132a1 1 0 000-1.664z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
              Watch
            </a>
            {%- endif -%}
            <a href="{{ talk.url }}" class="inline-flex items-center gap-1.5 text-xs font-semibold text-stone-600 hover:text-stone-800 bg-stone-100 hover:bg-stone-200 px-3 py-1.5 rounded-lg transition-colors">
              Details →
            </a>
          </div>
        </article>
      </div>
      {%- endfor -%}
    </div>
  </div>
</div>
