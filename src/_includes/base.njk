<!DOCTYPE html>
<html lang="en" class="scroll-smooth">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{{ title }} | {{ site.title }}</title>
  <meta name="description" content="{{ description or site.description }}">

  <meta property="og:title" content="{{ title }} | {{ site.title }}">
  <meta property="og:description" content="{{ description or site.description }}">
  <meta property="og:type" content="{% if tags and 'post' in tags %}article{% else %}website{% endif %}">
  <meta property="og:url" content="{{ site.url }}{{ page.url }}">
  <meta property="og:image" content="{{ site.url }}/assets/images/og-default.svg">
  <meta property="og:image:width" content="1200">
  <meta property="og:image:height" content="630">

  <meta name="twitter:card" content="summary_large_image">
  <meta name="twitter:title" content="{{ title }} | {{ site.title }}">
  <meta name="twitter:description" content="{{ description or site.description }}">
  <meta name="twitter:image" content="{{ site.url }}/assets/images/og-default.svg">

  <link rel="icon" href="/assets/images/favicon.svg" type="image/svg+xml">
  <link rel="alternate" type="application/atom+xml" title="{{ site.title }}" href="/feed/feed.xml">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&family=Source+Serif+4:ital,opsz,wght@0,8..60,300;0,8..60,400;0,8..60,600;1,8..60,400&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/assets/style.css">
  <link rel="stylesheet" href="/assets/prism-tomorrow.css">
</head>
<body class="bg-washi text-stone-900 font-sans antialiased">
  <div id="progress-bar" class="fixed top-0 left-0 h-0.5 z-[60] bg-amber-600 transition-all duration-75" style="width: 0%"></div>

  <header class="site-header sticky top-0 z-50">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="flex items-center justify-between h-16">
        <a href="/" class="brand-mark" aria-label="{{ site.title }} home">
          <span class="brand-seal" aria-hidden="true">
            <img src="/assets/images/ripple-spark.svg" alt="">
          </span>
          <span>
            <strong>{{ site.author }}</strong>
            <small>Software, people, attention</small>
          </span>
        </a>

        <nav class="hidden md:flex items-center gap-1" aria-label="Main navigation">
          <a href="/blog/" class="nav-link">Writing</a>
          <a href="/work-with-me/" class="nav-link">Work with me</a>
          <a href="/about/" class="nav-link">About</a>
          <a href="/search/" class="nav-link">Search</a>
          {%- if localDashboard.enabled %}
          <a href="/dashboard/" class="nav-link">Dashboard</a>
          {%- endif %}
          <a href="{{ site.linkedin }}" target="_blank" rel="noopener" class="nav-cta">LinkedIn</a>
        </nav>

        <button id="menu-toggle" class="md:hidden p-2 text-stone-700" aria-label="Toggle menu" aria-expanded="false">
          <svg id="menu-icon-open" class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 7h16M4 12h16M4 17h16"/></svg>
          <svg id="menu-icon-close" class="w-6 h-6 hidden" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M6 18L18 6M6 6l12 12"/></svg>
        </button>
      </div>
    </div>

    <div id="mobile-menu" class="hidden md:hidden mobile-menu">
      <nav class="px-4 py-4 grid gap-1" aria-label="Mobile navigation">
        <a href="/blog/" class="mobile-nav-link">Writing</a>
        <a href="/work-with-me/" class="mobile-nav-link">Work with me</a>
        <a href="/about/" class="mobile-nav-link">About</a>
        <a href="/search/" class="mobile-nav-link">Search</a>
        {%- if localDashboard.enabled %}
        <a href="/dashboard/" class="mobile-nav-link">Dashboard</a>
        {%- endif %}
        <a href="{{ site.linkedin }}" target="_blank" rel="noopener" class="mobile-nav-link text-amber-800">LinkedIn</a>
      </nav>
    </div>
  </header>

  <main class="min-h-screen">
{{ content | safe }}
  </main>

  <footer class="site-footer">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-14">
      <div class="grid grid-cols-1 md:grid-cols-3 gap-10">
        <div>
          <div class="eyebrow mb-4">The thread underneath</div>
          <h2 class="text-2xl font-semibold text-stone-100 mb-3">Better software starts with better attention.</h2>
          <p class="text-sm text-stone-400 leading-relaxed">{{ site.description }}</p>
        </div>
        <div>
          <h3 class="footer-heading">Explore</h3>
          <div class="grid gap-2 text-sm">
            <a href="/blog/">Writing</a>
            <a href="/work-with-me/">Work with me</a>
            <a href="/about/">About Roel</a>
          </div>
        </div>
        <div>
          <h3 class="footer-heading">Connect</h3>
          <div class="grid gap-2 text-sm">
            <a href="{{ site.linkedin }}" target="_blank" rel="noopener">LinkedIn</a>
            <a href="{{ site.sessionize }}" target="_blank" rel="noopener">Sessionize</a>
            <a href="{{ site.medium }}" target="_blank" rel="noopener">Medium</a>
            <a href="{{ site.github }}" target="_blank" rel="noopener">GitHub</a>
          </div>
        </div>
      </div>
      <div class="border-t border-stone-800 mt-10 pt-6 text-xs text-stone-500 flex flex-wrap justify-between gap-3">
        <span>&copy; {{ site.author }} 2026</span>
        <span>Built with curiosity, care, and a healthy suspicion of over-engineered solutions.</span>
      </div>
    </div>
  </footer>

  <script>
    var bar = document.getElementById('progress-bar');
    window.addEventListener('scroll', function() {
      var doc = document.documentElement;
      var total = doc.scrollHeight - doc.clientHeight;
      bar.style.width = total > 0 ? ((doc.scrollTop / total) * 100) + '%' : '0%';
    }, { passive: true });

    var toggle = document.getElementById('menu-toggle');
    var menu = document.getElementById('mobile-menu');
    var openIcon = document.getElementById('menu-icon-open');
    var closeIcon = document.getElementById('menu-icon-close');
    toggle.addEventListener('click', function() {
      var expanded = toggle.getAttribute('aria-expanded') === 'true';
      toggle.setAttribute('aria-expanded', String(!expanded));
      menu.classList.toggle('hidden');
      openIcon.classList.toggle('hidden');
      closeIcon.classList.toggle('hidden');
    });
  </script>
</body>
</html>
