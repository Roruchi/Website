---
layout: base.njk
---

<article>
  <header class="post-hero">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-16 md:py-24">
      <nav class="breadcrumb" aria-label="Breadcrumb">
        <a href="/blog/">Writing</a>
        <span>/</span>
        <span>{{ pillar }}</span>
      </nav>
      <div class="post-meta mt-8">
        <span>{{ pillar }}</span>
        <time datetime="{{ page.date | htmlDateString }}">{{ page.date | readableDate }}</time>
        <span>{{ content | readingTime }}</span>
      </div>
      <h1>{{ title }}</h1>
      <p class="post-deck">{{ description }}</p>
    </div>
  </header>

  <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 py-14">
    <div class="prose prose-stone prose-lg max-w-none article-body">
      {{ content | safe }}
    </div>

    <section class="ripple-panel"
      data-ripple-panel
      data-article-key="{{ page.url }}"
      data-api-url="{{ interactions.apiUrl }}"
      aria-labelledby="ripple-heading">
      <div>
        <div class="eyebrow mb-2">A quiet response</div>
        <h2 id="ripple-heading">Did this leave a ripple?</h2>
        <p>No score, no ranking. Just a small sign that the words reached someone.</p>
      </div>
      <button class="ripple-button" type="button" data-ripple-button aria-pressed="false">
        <span class="ripple-mark" aria-hidden="true"></span>
        <span data-ripple-label>Leave a ripple</span>
      </button>
      <p class="ripple-count" aria-live="polite">
        <span data-ripple-count>0</span> <span data-ripple-label-count>ripples</span> left
      </p>
    </section>

    {%- if originalUrl -%}
    <div class="source-note">
      <span>First published on Medium</span>
      <a href="{{ originalUrl }}" target="_blank" rel="noopener">View the original article</a>
    </div>
    {%- endif -%}

    {%- set articleTalkSlugs = relatedTalks -%}
    {%- set relatedPublicTalks = publicTalks | publicTalksBySlugs(articleTalkSlugs) -%}
    {%- if relatedPublicTalks.length > 0 -%}
    <section class="related-posts">
      <div class="eyebrow mb-5">Related talks</div>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
        {%- for talk in relatedPublicTalks -%}
        <a href="/talks/{{ talk.slug }}/" class="related-card">
          <span>{{ talk.status }}</span>
          <strong>{{ talk.title }}</strong>
          <small>Showcased talk</small>
        </a>
        {%- endfor -%}
      </div>
    </section>
    {%- endif -%}

    {%- set related = collections.post | relatedPosts(page.url, tags, 3) -%}
    {%- if related.length > 0 -%}
    <section class="related-posts">
      <div class="eyebrow mb-5">Continue wandering</div>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
        {%- for post in related -%}
        <a href="{{ post.url }}" class="related-card">
          <span>{{ post.data.pillar }}</span>
          <strong>{{ post.data.title }}</strong>
          <small>{{ post.date | readableDate }}</small>
        </a>
        {%- endfor -%}
      </div>
    </section>
    {%- endif -%}
  </div>
</article>
<script src="/assets/js/interactions.js"></script>
