---
layout: base.njk
title: Home
description: Software engineer, coach, and speaker mastering the intersection of code, coaching, and zen.
---

<!-- ══════════════════════════════════════════════════════════════════════════
     HERO — Full-viewport Sumi-e Koi Pond with text overlay
     ══════════════════════════════════════════════════════════════════════════ -->
<section class="relative min-h-[90vh] overflow-hidden bg-washi">

  <!-- Koi pond canvas fills the full section (click/tap to feed the fish) -->
  <div id="koi-pond-container" class="absolute inset-0"></div>

  <!-- "Feed the Koi" hint -->
  <div class="absolute bottom-8 left-1/2 -translate-x-1/2 z-20 flex items-center gap-2 opacity-30 pointer-events-none animate-bounce select-none">
    <svg class="w-3 h-3 text-stone-700" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 15l-2 5L9 9l11 4-5 2zm0 0l5 5"/></svg>
    <span class="text-[9px] uppercase tracking-[0.6em] font-bold text-stone-700">Feed the Koi</span>
  </div>

  <!-- Text overlay — left half of viewport -->
  <div class="relative z-10 min-h-[90vh] flex items-center pointer-events-none">
    <div class="max-w-6xl mx-auto px-8 sm:px-12 lg:px-24 w-full">
      <div class="max-w-lg lg:max-w-xl pointer-events-auto">

        <!-- Eyebrow line -->
        <div class="flex items-center gap-3 mb-8">
          <div class="w-8 h-px bg-amber-600"></div>
          <span class="text-[10px] uppercase tracking-[0.5em] font-bold text-amber-700">Practical Zen</span>
        </div>

        <h1 class="text-5xl md:text-6xl lg:text-7xl font-extrabold leading-tight tracking-tighter mb-8 text-stone-900">
          Mastering the intersection of
          <span class="block mt-1">Code, Coaching,</span>
          <span class="block mt-2 font-light italic text-stone-500">and Zen</span>
        </h1>

        <p class="text-lg text-stone-600 mb-10 leading-relaxed">
          {{ site.author }} is a software engineer, coach, and speaker — bridging technical precision with human insight.
        </p>

        <div class="flex flex-wrap gap-4">
          <a href="{{ '/talks/' | url }}" class="inline-flex items-center gap-2 bg-amber-500 hover:bg-amber-600 text-white font-semibold px-7 py-3.5 rounded-full transition-colors shadow-lg shadow-amber-500/20">
            Invite {{ site.author }} to Speak
          </a>
          <a href="{{ '/blog/' | url }}" class="inline-flex items-center gap-2 bg-transparent hover:bg-stone-100 text-stone-900 font-semibold px-7 py-3.5 rounded-full border border-stone-300 transition-colors">
            Read the Blog
          </a>
        </div>

      </div>
    </div>
  </div>
</section>

<!-- ── Stats Bar ─────────────────────────────────────────────────────────── -->
<section class="bg-white border-y border-stone-100 shadow-sm">
  <div class="max-w-6xl mx-auto px-4 py-8">
    <div class="grid grid-cols-2 md:grid-cols-4 gap-6 text-center">
      <div>
        <div class="text-3xl font-bold text-stone-900">{{ collections.post | length }}</div>
        <div class="text-sm text-stone-400 mt-1">Blog Posts</div>
      </div>
      <div>
        <div class="text-3xl font-bold text-amber-600">{{ collections.talk | length }}</div>
        <div class="text-sm text-stone-400 mt-1">Talks Given</div>
      </div>
      <div>
        <div class="text-3xl font-bold text-stone-900">{{ collections.training | length }}</div>
        <div class="text-sm text-stone-400 mt-1">Workshops</div>
      </div>
      <div>
        <div class="text-3xl font-bold text-amber-600">10+</div>
        <div class="text-sm text-stone-400 mt-1">Years Experience</div>
      </div>
    </div>
  </div>
</section>

<!-- ── What I Do ─────────────────────────────────────────────────────────── -->
<section class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-20">
  <h2 class="text-3xl font-bold text-stone-900 mb-2">What I Do</h2>
  <p class="text-stone-500 mb-12">Sharing knowledge through writing, speaking, and hands-on training.</p>

  <div class="grid grid-cols-1 md:grid-cols-3 gap-8">

    <!-- Blog Card -->
    <div class="group bg-white rounded-2xl shadow-sm hover:shadow-xl transition-all duration-300 overflow-hidden border border-stone-100 hover:border-amber-200 hover:-translate-y-1">
      <div class="bg-stone-900 p-6">
        <div class="text-4xl mb-2">✍️</div>
        <h3 class="text-xl font-bold text-white">Blog</h3>
      </div>
      <div class="p-6">
        <p class="text-stone-500 text-sm mb-4">In-depth articles on platform engineering, TypeScript, and developer experience.</p>
        <ul class="space-y-2 mb-6">
          {%- for post in collections.post | reverse | head(3) -%}
          <li class="text-sm text-stone-700 truncate">→ <a href="{{ post.url | url }}" class="hover:text-amber-700 transition-colors">{{ post.data.title }}</a></li>
          {%- endfor -%}
        </ul>
        <a href="{{ '/blog/' | url }}" class="inline-flex items-center text-sm font-semibold text-stone-900 hover:text-amber-700 transition-colors gap-1">
          All posts <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6"/></svg>
        </a>
      </div>
    </div>

    <!-- Talks Card -->
    <div class="group bg-white rounded-2xl shadow-sm hover:shadow-xl transition-all duration-300 overflow-hidden border border-stone-100 hover:border-amber-200 hover:-translate-y-1">
      <div class="bg-amber-600 p-6">
        <div class="text-4xl mb-2">🎤</div>
        <h3 class="text-xl font-bold text-white">Talks</h3>
      </div>
      <div class="p-6">
        <p class="text-stone-500 text-sm mb-4">Conference talks and workshops at events like PlatformCon, KubeCon, and TSConf.</p>
        <ul class="space-y-2 mb-6">
          {%- for talk in collections.talk | reverse | head(3) -%}
          <li class="text-sm text-stone-700 truncate">→ <a href="{{ talk.url | url }}" class="hover:text-amber-700 transition-colors">{{ talk.data.title }}</a></li>
          {%- endfor -%}
        </ul>
        <a href="{{ '/talks/' | url }}" class="inline-flex items-center text-sm font-semibold text-stone-900 hover:text-amber-700 transition-colors gap-1">
          All talks <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6"/></svg>
        </a>
      </div>
    </div>

    <!-- Trainings Card -->
    <div class="group bg-white rounded-2xl shadow-sm hover:shadow-xl transition-all duration-300 overflow-hidden border border-stone-100 hover:border-amber-200 hover:-translate-y-1">
      <div class="bg-stone-700 p-6">
        <div class="text-4xl mb-2">🎓</div>
        <h3 class="text-xl font-bold text-white">Trainings</h3>
      </div>
      <div class="p-6">
        <p class="text-stone-500 text-sm mb-4">Hands-on workshops for engineering teams on platform engineering and TypeScript.</p>
        <ul class="space-y-2 mb-6">
          {%- for training in collections.training | reverse | head(3) -%}
          <li class="text-sm text-stone-700 truncate">→ <a href="{{ training.url | url }}" class="hover:text-amber-700 transition-colors">{{ training.data.title }}</a></li>
          {%- endfor -%}
        </ul>
        <a href="{{ '/trainings/' | url }}" class="inline-flex items-center text-sm font-semibold text-stone-900 hover:text-amber-700 transition-colors gap-1">
          All workshops <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6"/></svg>
        </a>
      </div>
    </div>

  </div>
</section>

<!-- ── Latest Posts ───────────────────────────────────────────────────────── -->
<section class="bg-white border-y border-stone-100 py-20">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex items-center justify-between mb-12">
      <div>
        <h2 class="text-3xl font-bold text-stone-900 mb-2">Latest Posts</h2>
        <p class="text-stone-500">Recent thoughts and tutorials.</p>
      </div>
      <a href="{{ '/blog/' | url }}" class="hidden md:inline-flex items-center gap-1 text-sm font-semibold text-stone-700 hover:text-amber-700 transition-colors">
        View all <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6"/></svg>
      </a>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
      {%- for post in collections.post | reverse | head(3) -%}
      <article class="group bg-washi hover:bg-white rounded-xl p-6 border border-stone-200 hover:border-amber-200 hover:shadow-md transition-all duration-200">
        <div class="flex flex-wrap gap-2 mb-3">
          {%- for tag in post.data.tags -%}
          {%- if tag != "post" -%}
          <span class="text-xs font-medium text-amber-800 bg-amber-100 px-2 py-0.5 rounded-full">{{ tag }}</span>
          {%- endif -%}
          {%- endfor -%}
        </div>
        <h3 class="font-bold text-stone-900 mb-2 group-hover:text-amber-800 transition-colors leading-snug">
          <a href="{{ post.url | url }}">{{ post.data.title }}</a>
        </h3>
        <p class="text-sm text-stone-500 mb-4 line-clamp-2">{{ post.data.description }}</p>
        <div class="flex items-center text-xs text-stone-400">
          <time datetime="{{ post.date | htmlDateString }}">{{ post.date | readableDate }}</time>
        </div>
      </article>
      {%- endfor -%}
    </div>
  </div>
</section>

<script src="{{ '/assets/js/koi-pond.js' | url }}"></script>
