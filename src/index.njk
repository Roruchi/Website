---
layout: base.njk
title: Home
description: Software engineer, speaker, and trainer.
---

<!-- Hero Section -->
<section class="bg-gradient-to-br from-slate-900 via-violet-950 to-slate-900 text-white py-24 px-4">
  <div class="max-w-5xl mx-auto">
    <div class="flex flex-col md:flex-row items-center gap-12">
      <div class="flex-1">
        <div class="inline-flex items-center gap-2 bg-violet-500/20 text-violet-300 text-sm font-medium px-3 py-1 rounded-full mb-6 border border-violet-500/30">
          <span class="w-2 h-2 rounded-full bg-violet-400 animate-pulse"></span>
          Available for workshops &amp; speaking
        </div>
        <h1 class="text-5xl md:text-6xl font-extrabold mb-6 leading-tight">
          Hi, I'm <span class="bg-gradient-to-r from-violet-400 to-cyan-400 bg-clip-text text-transparent">{{ site.author }}</span>
        </h1>
        <p class="text-xl text-slate-300 mb-8 leading-relaxed max-w-xl">
          Software engineer, conference speaker, and trainer. I write about platform engineering, TypeScript, and developer experience.
        </p>
        <div class="flex flex-wrap gap-4">
          <a href="/blog/" class="inline-flex items-center gap-2 bg-violet-600 hover:bg-violet-500 text-white font-semibold px-6 py-3 rounded-lg transition-colors">
            Read the Blog
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6"/></svg>
          </a>
          <a href="/about/" class="inline-flex items-center gap-2 bg-transparent hover:bg-white/10 text-white font-semibold px-6 py-3 rounded-lg border border-white/20 transition-colors">
            About Me
          </a>
        </div>
      </div>
      <!-- Avatar placeholder -->
      <div class="flex-shrink-0">
        <div class="w-48 h-48 md:w-56 md:h-56 rounded-full overflow-hidden ring-4 ring-violet-500/50 ring-offset-4 ring-offset-slate-900 shadow-2xl bg-gradient-to-br from-violet-500 to-cyan-500 flex items-center justify-center">
          <span class="text-7xl">👨‍💻</span>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- Stats Bar -->
<section class="bg-white dark:bg-slate-800 border-b border-slate-200 dark:border-slate-700 shadow-sm">
  <div class="max-w-5xl mx-auto px-4 py-8">
    <div class="grid grid-cols-2 md:grid-cols-4 gap-6 text-center">
      <div>
        <div class="text-3xl font-bold text-violet-600">{{ collections.post | length }}</div>
        <div class="text-sm text-slate-500 dark:text-slate-400 mt-1">Blog Posts</div>
      </div>
      <div>
        <div class="text-3xl font-bold text-cyan-600">{{ collections.talk | length }}</div>
        <div class="text-sm text-slate-500 dark:text-slate-400 mt-1">Talks Given</div>
      </div>
      <div>
        <div class="text-3xl font-bold text-violet-600">{{ collections.training | length }}</div>
        <div class="text-sm text-slate-500 dark:text-slate-400 mt-1">Workshops</div>
      </div>
      <div>
        <div class="text-3xl font-bold text-cyan-600">10+</div>
        <div class="text-sm text-slate-500 dark:text-slate-400 mt-1">Years Experience</div>
      </div>
    </div>
  </div>
</section>

<!-- Section Cards -->
<section class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 py-20">
  <h2 class="text-3xl font-bold text-slate-900 dark:text-white mb-2">What I Do</h2>
  <p class="text-slate-500 dark:text-slate-400 mb-12">Sharing knowledge through writing, speaking, and hands-on training.</p>

  <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
    <!-- Blog Card -->
    <div class="group bg-white dark:bg-slate-800 rounded-2xl shadow-sm hover:shadow-xl transition-all duration-300 overflow-hidden border border-slate-100 dark:border-slate-700 hover:border-violet-200 hover:-translate-y-1">
      <div class="bg-gradient-to-br from-violet-500 to-violet-700 p-6">
        <div class="text-4xl mb-2">✍️</div>
        <h3 class="text-xl font-bold text-white">Blog</h3>
      </div>
      <div class="p-6">
        <p class="text-slate-600 dark:text-slate-400 text-sm mb-4">In-depth articles on platform engineering, TypeScript, and developer experience.</p>
        <ul class="space-y-2 mb-6">
          {%- for post in collections.post | reverse | head(3) -%}
          <li class="text-sm text-slate-700 dark:text-slate-300 truncate">→ <a href="{{ post.url }}" class="hover:text-violet-600 transition-colors">{{ post.data.title }}</a></li>
          {%- endfor -%}
        </ul>
        <a href="/blog/" class="inline-flex items-center text-sm font-semibold text-violet-600 hover:text-violet-700 transition-colors gap-1">
          All posts <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6"/></svg>
        </a>
      </div>
    </div>

    <!-- Talks Card -->
    <div class="group bg-white dark:bg-slate-800 rounded-2xl shadow-sm hover:shadow-xl transition-all duration-300 overflow-hidden border border-slate-100 dark:border-slate-700 hover:border-cyan-200 hover:-translate-y-1">
      <div class="bg-gradient-to-br from-cyan-500 to-cyan-700 p-6">
        <div class="text-4xl mb-2">🎤</div>
        <h3 class="text-xl font-bold text-white">Talks</h3>
      </div>
      <div class="p-6">
        <p class="text-slate-600 dark:text-slate-400 text-sm mb-4">Conference talks and workshops at events like PlatformCon, KubeCon, and TSConf.</p>
        <ul class="space-y-2 mb-6">
          {%- for talk in collections.talk | reverse | head(3) -%}
          <li class="text-sm text-slate-700 dark:text-slate-300 truncate">→ <a href="{{ talk.url }}" class="hover:text-cyan-600 transition-colors">{{ talk.data.title }}</a></li>
          {%- endfor -%}
        </ul>
        <a href="/talks/" class="inline-flex items-center text-sm font-semibold text-cyan-600 hover:text-cyan-700 transition-colors gap-1">
          All talks <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6"/></svg>
        </a>
      </div>
    </div>

    <!-- Trainings Card -->
    <div class="group bg-white dark:bg-slate-800 rounded-2xl shadow-sm hover:shadow-xl transition-all duration-300 overflow-hidden border border-slate-100 dark:border-slate-700 hover:border-emerald-200 hover:-translate-y-1">
      <div class="bg-gradient-to-br from-emerald-500 to-emerald-700 p-6">
        <div class="text-4xl mb-2">🎓</div>
        <h3 class="text-xl font-bold text-white">Trainings</h3>
      </div>
      <div class="p-6">
        <p class="text-slate-600 dark:text-slate-400 text-sm mb-4">Hands-on workshops for engineering teams on platform engineering and TypeScript.</p>
        <ul class="space-y-2 mb-6">
          {%- for training in collections.training | reverse | head(3) -%}
          <li class="text-sm text-slate-700 dark:text-slate-300 truncate">→ <a href="{{ training.url }}" class="hover:text-emerald-600 transition-colors">{{ training.data.title }}</a></li>
          {%- endfor -%}
        </ul>
        <a href="/trainings/" class="inline-flex items-center text-sm font-semibold text-emerald-600 hover:text-emerald-700 transition-colors gap-1">
          All workshops <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6"/></svg>
        </a>
      </div>
    </div>
  </div>
</section>

<!-- Recent Blog Posts -->
<section class="bg-white dark:bg-slate-800 border-y border-slate-200 dark:border-slate-700 py-20">
  <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex items-center justify-between mb-12">
      <div>
        <h2 class="text-3xl font-bold text-slate-900 dark:text-white mb-2">Latest Posts</h2>
        <p class="text-slate-500 dark:text-slate-400">Recent thoughts and tutorials.</p>
      </div>
      <a href="/blog/" class="hidden md:inline-flex items-center gap-1 text-sm font-semibold text-violet-600 hover:text-violet-700 transition-colors">
        View all <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6"/></svg>
      </a>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
      {%- for post in collections.post | reverse | head(3) -%}
      <article class="group bg-slate-50 dark:bg-slate-900 hover:bg-white dark:hover:bg-slate-700 rounded-xl p-6 border border-slate-200 dark:border-slate-700 hover:border-violet-200 hover:shadow-md transition-all duration-200">
        <div class="flex flex-wrap gap-2 mb-3">
          {%- for tag in post.data.tags -%}
          {%- if tag != "post" -%}
          <span class="text-xs font-medium text-violet-700 bg-violet-100 px-2 py-0.5 rounded-full">{{ tag }}</span>
          {%- endif -%}
          {%- endfor -%}
        </div>
        <h3 class="font-bold text-slate-900 dark:text-white mb-2 group-hover:text-violet-700 transition-colors leading-snug">
          <a href="{{ post.url }}">{{ post.data.title }}</a>
        </h3>
        <p class="text-sm text-slate-500 dark:text-slate-400 mb-4 line-clamp-2">{{ post.data.description }}</p>
        <div class="flex items-center text-xs text-slate-400">
          <time datetime="{{ post.date | htmlDateString }}">{{ post.date | readableDate }}</time>
        </div>
      </article>
      {%- endfor -%}
    </div>
  </div>
</section>
