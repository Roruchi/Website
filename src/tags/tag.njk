---
layout: base.njk
pagination:
  data: collections
  size: 1
  alias: tag
  filter:
    - all
    - post
    - talk
    - training
    - tagList
permalink: /tags/{{ tag | slug }}/index.html
eleventyComputed:
  title: "Posts tagged: {{ tag }}"
---
<div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
  <nav class="text-sm text-slate-500 mb-8">
    <a href="/" class="hover:text-violet-600 transition-colors">Home</a>
    <span class="mx-2">/</span>
    <a href="/tags/" class="hover:text-violet-600 transition-colors">Tags</a>
    <span class="mx-2">/</span>
    <span class="text-slate-700 dark:text-slate-300">{{ tag }}</span>
  </nav>
  <h1 class="text-4xl font-extrabold text-slate-900 dark:text-white mb-4">
    Posts tagged: <span class="text-violet-600">#{{ tag }}</span>
  </h1>
  <div class="grid grid-cols-1 gap-6 mt-10">
    {%- for post in collections[tag] | reverse -%}
    {%- if post.data.tags and "post" in post.data.tags -%}
    <article class="bg-white dark:bg-slate-800 rounded-xl border border-slate-200 dark:border-slate-700 p-6 hover:border-violet-300 hover:shadow-md transition-all">
      <h2 class="font-bold text-slate-900 dark:text-white text-lg mb-2">
        <a href="{{ post.url }}" class="hover:text-violet-600 transition-colors">{{ post.data.title }}</a>
      </h2>
      <p class="text-slate-500 dark:text-slate-400 text-sm mb-3">{{ post.data.description }}</p>
      <time class="text-xs text-slate-400">{{ post.date | readableDate }}</time>
    </article>
    {%- endif -%}
    {%- endfor -%}
  </div>
</div>
