---
layout: base.njk
pagination:
  data: collections
  size: 1
  alias: tag
  filter:
    - all
    - post
    - talk
    - training
    - tagList
permalink: /tags/{{ tag | slug }}/index.html
eleventyComputed:
  title: "Posts tagged: {{ tag }}"
---
<div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
  <nav class="text-sm text-stone-400 mb-8">
    <a href="{{ '/' | url }}" class="hover:text-amber-700 transition-colors">Home</a>
    <span class="mx-2">/</span>
    <a href="{{ '/tags/' | url }}" class="hover:text-amber-700 transition-colors">Tags</a>
    <span class="mx-2">/</span>
    <span class="text-stone-600">{{ tag }}</span>
  </nav>
  <h1 class="text-4xl font-extrabold text-stone-900 mb-4">
    Posts tagged: <span class="text-amber-700">#{{ tag }}</span>
  </h1>
  <div class="grid grid-cols-1 gap-6 mt-10">
    {%- for post in collections[tag] | reverse -%}
    {%- if post.data.tags and "post" in post.data.tags -%}
    <article class="bg-white rounded-xl border border-stone-200 p-6 hover:border-amber-300 hover:shadow-md transition-all">
      <h2 class="font-bold text-stone-900 text-lg mb-2">
        <a href="{{ post.url | url }}" class="hover:text-amber-700 transition-colors">{{ post.data.title }}</a>
      </h2>
      <p class="text-stone-500 text-sm mb-3">{{ post.data.description }}</p>
      <time class="text-xs text-stone-400">{{ post.date | readableDate }}</time>
    </article>
    {%- endif -%}
    {%- endfor -%}
  </div>
</div>
